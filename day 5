//PROBLEM 1 
//Pattern printing upper roght angle triangle and its opposite
#include <iostream>
using namespace std;
int main(){
int n;
cin>>n;

//print upper right angle triangle
for(int i=1;i<=n;i++){
       for(int j=1;j<=i;j++){
           cout<<"*";
       } cout<<endl;
    }
    //print lower triangle
for(int k =n-1;k>=1;k--){
    for(int t=1;t<=k;t++){
        cout<<"*";
    }cout<<endl;
}    

    return 0;
}

