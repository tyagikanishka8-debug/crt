// problem 3
//Pillar of OOPS
//Encapsulation
//encapsulation means we are binding the data into a single unit(functions,data,variables,methods)
//into a single unit called class and making some restrictions on this class members
//data security
//controlled access over my data with the help of access specifier
//validation before accessing the data
//code maintainaility
//
#include<iostream>
using namespace std;

class bankAccount{
private:
int balance;

public:
void setbalance(int amount){
    if(amount >= 0){
        balance = amount;
       
    }else{
        cout<<"Enter a valid number..";
    }
}

public:
int getbalance(){
    return balance;
}

};

int main(){
    bankAccount obj1;
    obj1.setbalance(5000);
    cout<<obj1.getbalance();
    return 0;
}

