// problem 3 
//Call by value //call by refrence
//call by value -- photocopy
// call by refrence -- original copy(address)

#include <iostream>
using namespace std;

void updatebyValue(int a){
    a = 500;
}

void updatebyRefrence(int &a){
    a = 500;
}

int main(){
    int original = 100;
    
    updatebyValue(original);
    cout<< original<<endl;
    updatebyRefrence(original);
    cout<<original;

    return 0;
}

